---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
---

<Layout
    title="Páginas Web Realizadas | Casos de Éxito de Nuestros Clientes"
    description="Mira cómo ayudamos a otros negocios a tener presencia en internet. Páginas web que cargan al instante en cualquier celular."
>
    <Navbar />

    <div
        class="flex-grow flex flex-col relative w-full"
        x-data="{ filter: 'all' }"
    >
        <div
            class="fixed top-0 right-0 w-[600px] h-[600px] bg-blue-600/10 blur-[150px] rounded-full pointer-events-none z-0"
        >
        </div>

        <header
            class="w-full pt-28 md:pt-32 pb-12 px-6 relative z-10 text-center"
        >
            <div class="max-w-4xl mx-auto">
                <div
                    class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/30 text-blue-400 px-4 py-2 rounded-full text-xs font-black uppercase tracking-widest mb-6"
                >
                    <i class="fas fa-medal"></i> Casos de Éxito Reales
                </div>
                <h1
                    class="text-4xl md:text-6xl font-black italic uppercase tracking-tighter mb-6 leading-tight text-white"
                >
                    Proyectos que ya están
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400"
                        >ONLINE</span
                    >
                </h1>
                <p class="text-slate-400 font-medium text-lg max-w-2xl mx-auto">
                    No prometemos rendimiento, lo demostramos en la cancha.
                    Explora las páginas de nuestros clientes y comprueba la
                    velocidad tú mismo.
                </p>
            </div>
        </header>

        <div
            class="relative z-20 flex justify-center px-4 mb-12 w-full max-w-2xl mx-auto"
        >
            <div
                class="bg-slate-900/80 backdrop-blur-md p-1.5 rounded-full border border-slate-800 flex w-full gap-1 shadow-xl overflow-x-auto no-scrollbar"
            >
                <button
                    @click="filter = 'all'"
                    class="flex-1 py-2.5 px-3 rounded-full text-xs md:text-sm font-black uppercase tracking-widest transition-all flex items-center justify-center whitespace-nowrap"
                    :class="filter === 'all' ? 'bg-slate-700 text-white shadow-inner' : 'text-slate-400 hover:text-white'"
                    >Todos</button
                >
                <button
                    @click="filter = 'l1'"
                    class="flex-1 py-2.5 px-3 rounded-full text-xs md:text-sm font-black uppercase tracking-widest transition-all flex items-center justify-center whitespace-nowrap"
                    :class="filter === 'l1' ? 'bg-orange-500/20 text-orange-400 border border-orange-500/30 shadow-inner' : 'text-slate-400 hover:text-white border border-transparent'"
                    >Nivel 1</button
                >
                <button
                    @click="filter = 'l2'"
                    class="flex-1 py-2.5 px-3 rounded-full text-xs md:text-sm font-black uppercase tracking-widest transition-all flex items-center justify-center whitespace-nowrap"
                    :class="filter === 'l2' ? 'bg-blue-500/20 text-blue-400 border border-blue-500/30 shadow-inner' : 'text-slate-400 hover:text-white border border-transparent'"
                    >Nivel 2</button
                >
                <button
                    @click="filter = 'l3'"
                    class="flex-1 py-2.5 px-3 rounded-full text-xs md:text-sm font-black uppercase tracking-widest transition-all flex items-center justify-center whitespace-nowrap"
                    :class="filter === 'l3' ? 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 shadow-inner' : 'text-slate-400 hover:text-white border border-transparent'"
                    >Nivel 3</button
                >
            </div>
        </div>

        <main
            class="flex-grow w-full max-w-7xl mx-auto px-6 pb-24 relative z-10"
        >
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Portafolio 1 -->
                <div
                    x-show="filter === 'all' || filter === 'l1'"
                    x-transition:enter="transition ease-out duration-300"
                    x-transition:enter-start="opacity-0 scale-95"
                    x-transition:enter-end="opacity-100 scale-100"
                >
                    <a
                        href="https://doctoraselene.com"
                        target="_blank"
                        class="group flex flex-col bg-slate-900/60 backdrop-blur-sm border border-slate-800 rounded-[2rem] overflow-hidden hover:border-orange-500/50 transition-all duration-500 shadow-lg hover:shadow-[0_10px_30px_rgba(249,115,22,0.15)] relative h-full"
                    >
                        <div
                            class="w-full h-56 bg-slate-800 overflow-hidden relative"
                        >
                            <img
                                src="/imgs/agencia-digital-diseno-web-doctor.avif"
                                alt="Web Clínica Dra. Selene"
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out"
                            />
                            <div
                                class="absolute inset-0 bg-slate-950/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center"
                            >
                                <span
                                    class="bg-orange-600 text-white font-black text-xs uppercase tracking-widest px-6 py-3 rounded-full flex items-center gap-2"
                                    >Ver Web en Vivo <i
                                        class="fas fa-external-link-alt"
                                    ></i></span
                                >
                            </div>
                        </div>
                        <div class="p-6 md:p-8 flex flex-col grow">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <p
                                        class="text-orange-400 text-[10px] font-black uppercase tracking-widest mb-1"
                                    >
                                        Sector Salud • Nivel 1
                                    </p>
                                    <h3
                                        class="text-xl font-bold text-white leading-tight"
                                    >
                                        Clínica Dra. Selene
                                    </h3>
                                </div>
                            </div>
                            <p class="text-slate-400 text-sm mb-6 grow">
                                Plataforma médica optimizada para generar
                                confianza y facilitar la reserva de citas de los
                                pacientes.
                            </p>
                            <div
                                class="flex items-center gap-2 text-[11px] font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-2 rounded-lg w-max mt-auto uppercase tracking-wider"
                            >
                                <i class="fas fa-bolt"></i> Carga Instantánea
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Portafolio 2 -->
                <div
                    x-show="filter === 'all' || filter === 'l1'"
                    x-transition:enter="transition ease-out duration-300"
                    x-transition:enter-start="opacity-0 scale-95"
                    x-transition:enter-end="opacity-100 scale-100"
                >
                    <a
                        href="https://purofierrocampoy.com/"
                        target="_blank"
                        class="group flex flex-col bg-slate-900/60 backdrop-blur-sm border border-slate-800 rounded-[2rem] overflow-hidden hover:border-orange-500/50 transition-all duration-500 shadow-lg hover:shadow-[0_10px_30px_rgba(249,115,22,0.15)] relative h-full"
                    >
                        <div
                            class="w-full h-56 bg-slate-800 overflow-hidden relative"
                        >
                            <img
                                src="/imgs/marketing-digital-gamarra-paginas-web.avif"
                                alt="Web Puro Fierro Gym"
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out"
                            />
                            <div
                                class="absolute inset-0 bg-slate-950/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center"
                            >
                                <span
                                    class="bg-orange-600 text-white font-black text-xs uppercase tracking-widest px-6 py-3 rounded-full flex items-center gap-2"
                                    >Ver Web en Vivo <i
                                        class="fas fa-external-link-alt"
                                    ></i></span
                                >
                            </div>
                        </div>
                        <div class="p-6 md:p-8 flex flex-col grow">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <p
                                        class="text-orange-400 text-[10px] font-black uppercase tracking-widest mb-1"
                                    >
                                        Sector Fitness • Nivel 1
                                    </p>
                                    <h3
                                        class="text-xl font-bold text-white leading-tight"
                                    >
                                        Puro Fierro Gym
                                    </h3>
                                </div>
                            </div>
                            <p class="text-slate-400 text-sm mb-6 grow">
                                Landing page dinámica y de alto contraste
                                diseñada para la captación de nuevos miembros al
                                gimnasio.
                            </p>
                            <div
                                class="flex items-center gap-2 text-[11px] font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-2 rounded-lg w-max mt-auto uppercase tracking-wider"
                            >
                                <i class="fas fa-bolt"></i> Carga Instantánea
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Portafolio 3 -->
                <div
                    x-show="filter === 'all' || filter === 'l1'"
                    x-transition:enter="transition ease-out duration-300"
                    x-transition:enter-start="opacity-0 scale-95"
                    x-transition:enter-end="opacity-100 scale-100"
                >
                    <a
                        href="https://www.perforacionesmagnus.com"
                        target="_blank"
                        class="group flex flex-col bg-slate-900/60 backdrop-blur-sm border border-slate-800 rounded-[2rem] overflow-hidden hover:border-orange-500/50 transition-all duration-500 shadow-lg hover:shadow-[0_10px_30px_rgba(249,115,22,0.15)] relative h-full"
                    >
                        <div
                            class="w-full h-56 bg-slate-800 overflow-hidden relative"
                        >
                            <img
                                src="/imgs/servicio-pagina-web-peru-barato.avif"
                                alt="Web Perforaciones Magnus"
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out"
                            />
                            <div
                                class="absolute inset-0 bg-slate-950/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center"
                            >
                                <span
                                    class="bg-orange-600 text-white font-black text-xs uppercase tracking-widest px-6 py-3 rounded-full flex items-center gap-2"
                                    >Ver Web en Vivo <i
                                        class="fas fa-external-link-alt"
                                    ></i></span
                                >
                            </div>
                        </div>
                        <div class="p-6 md:p-8 flex flex-col grow">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <p
                                        class="text-orange-400 text-[10px] font-black uppercase tracking-widest mb-1"
                                    >
                                        Sector Ingeniería • Nivel 1
                                    </p>
                                    <h3
                                        class="text-xl font-bold text-white leading-tight"
                                    >
                                        Perf. Magnus
                                    </h3>
                                </div>
                            </div>
                            <p class="text-slate-400 text-sm mb-6 grow">
                                Web corporativa con estructura sólida para
                                presentar servicios industriales y proyectos
                                B2B.
                            </p>
                            <div
                                class="flex items-center gap-2 text-[11px] font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-2 rounded-lg w-max mt-auto uppercase tracking-wider"
                            >
                                <i class="fas fa-check-double"></i> SEO Optimizado
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Placeholders para L2 y L3 -->
            <div
                x-show="filter === 'l2'"
                style="display: none"
                class="w-full py-16 text-center border-2 border-dashed border-slate-800 rounded-3xl mt-8"
            >
                <div
                    class="w-20 h-20 bg-blue-900/20 text-blue-500 rounded-full flex items-center justify-center text-3xl mx-auto mb-6"
                >
                    <i class="fas fa-briefcase"></i>
                </div>
                <h3
                    class="text-2xl font-black text-white italic uppercase tracking-tighter mb-3"
                >
                    Proyectos en Horno
                </h3>
                <p class="text-slate-400 max-w-md mx-auto mb-6">
                    Estamos cocinando nuevas webs corporativas en este momento.
                </p>
                <a
                    href="https://wa.me/51963896469?text=Hola,%20me%20gustaría%20ser%20su%20próximo%20caso%20de%20éxito%20en%20el%20Nivel%202."
                    target="_blank"
                    class="inline-block bg-blue-600 hover:bg-blue-500 text-white font-bold text-xs uppercase tracking-widest px-6 py-3 rounded-full transition-colors"
                    >Sé nuestro próximo caso de éxito L2</a
                >
            </div>

            <div
                x-show="filter === 'l3'"
                style="display: none"
                class="w-full py-16 text-center border-2 border-dashed border-slate-800 rounded-3xl mt-8"
            >
                <div
                    class="w-20 h-20 bg-emerald-900/20 text-emerald-500 rounded-full flex items-center justify-center text-3xl mx-auto mb-6"
                >
                    <i class="fas fa-store"></i>
                </div>
                <h3
                    class="text-2xl font-black text-white italic uppercase tracking-tighter mb-3"
                >
                    E-commerce en Producción
                </h3>
                <p class="text-slate-400 max-w-md mx-auto mb-6">
                    Nuestros desarrolladores están ensamblando tiendas online
                    justo ahora.
                </p>
                <a
                    href="https://wa.me/51963896469?text=Hola,%20me%20gustaría%20construir%20mi%20Tienda%20Online%20(Nivel%203)%20con%20ustedes."
                    target="_blank"
                    class="inline-block bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs uppercase tracking-widest px-6 py-3 rounded-full transition-colors"
                    >Construye tu Tienda L3 hoy</a
                >
            </div>
        </main>

        <section
            class="w-full py-16 bg-gradient-to-b from-transparent to-slate-900/80 border-t border-slate-800 text-center relative z-10"
        >
            <h2
                class="text-2xl md:text-4xl font-black italic uppercase tracking-tighter text-white mb-4"
            >
                ¿Listo para unirte a la lista?
            </h2>
            <p class="text-slate-400 mb-8 max-w-xl mx-auto">
                Deja de perder clientes por tener una web lenta o antigua.
                Elévate a los estándares del 2026.
            </p>
            <a
                href="/planes"
                class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-blue-600 hover:bg-blue-500 text-white rounded-full font-black text-xs uppercase tracking-widest transition-all shadow-lg shadow-blue-900/50"
            >
                Ver Planes y Precios <i class="fas fa-arrow-right"></i>
            </a>
        </section>
    </div>

    <Footer />
    <FloatingWhatsApp />
</Layout>
