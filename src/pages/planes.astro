                        <div
                            class="flex flex-col lg:grid lg:grid-cols-12 gap-8 mb-8"
                        >
                            <div
                                class="order-2 lg:order-1 lg:col-span-7 bg-slate-950/50 border border-slate-800/80 rounded-[2rem] p-6 md:p-8 grid grid-cols-1 sm:grid-cols-2 gap-6 content-start"
