                            </div>
                            <div
                                class="order-1 lg:order-2 lg:col-span-5 flex flex-col gap-6 h-full"
                            >
                                <div
                                    class="bg-slate-900 p-3 rounded-[2rem] mockup-glow-l1 flex items-center justify-center flex-1 w-full"
