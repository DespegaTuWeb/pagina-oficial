---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
---

<Layout
    title="Planes | DespegaTuWeb"
    description="Encuentra el nivel de despegue ideal para tu negocio."
>
    <Navbar />

    <!-- CONTENEDOR ALPINE PARA EL MANEJO DE PESTAÑAS (TABS) -->
    <div
        class="flex-grow flex flex-col relative w-full"
        x-data="{ tab: window.location.hash ? window.location.hash.substring(1) : 'l1' }"
        @hashchange.window="tab = window.location.hash ? window.location.hash.substring(1) : 'l1'"
    >
        <div
            class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] blur-[150px] rounded-full pointer-events-none z-0 transition-colors duration-700"
            :class="{
                'bg-orange-600/10': tab === 'l1',
                'bg-blue-600/10': tab === 'l2',
                'bg-emerald-600/10': tab === 'l3'
            }"
        >
        </div>

        <div
            class="relative z-20 flex justify-center px-4 mt-24 md:mt-28 mb-2 w-full max-w-xl mx-auto"
        >
            <div
                class="bg-slate-900/80 backdrop-blur-md p-1.5 rounded-full border border-slate-800 flex w-full gap-1 shadow-xl"
            >
                <button
                    @click="window.location.hash = 'l1'"
                    class="flex-1 py-2.5 px-1 rounded-full border text-[10px] sm:text-xs md:text-sm font-black uppercase tracking-tighter sm:tracking-widest transition-all flex items-center justify-center"
                    :class="tab === 'l1' ? 'bg-orange-500/20 text-orange-400 border-orange-500/50 shadow-inner' : 'text-slate-400 hover:text-white border-transparent'"
                >
                    <i class="fas fa-bolt mr-1.5 md:mr-2"></i> Nivel 1
                </button>
                <button
                    @click="window.location.hash = 'l2'"
                    class="flex-1 py-2.5 px-1 rounded-full border text-[10px] sm:text-xs md:text-sm font-black uppercase tracking-tighter sm:tracking-widest transition-all flex items-center justify-center"
                    :class="tab === 'l2' ? 'bg-blue-500/20 text-blue-400 border-blue-500/50 shadow-inner' : 'text-slate-400 hover:text-white border-transparent'"
                >
                    <i class="fas fa-briefcase mr-1.5 md:mr-2"></i> Nivel 2
                </button>
                <button
                    @click="window.location.hash = 'l3'"
                    class="flex-1 py-2.5 px-1 rounded-full border text-[10px] sm:text-xs md:text-sm font-black uppercase tracking-tighter sm:tracking-widest transition-all flex items-center justify-center"
                    :class="tab === 'l3' ? 'bg-emerald-500/20 text-emerald-400 border-emerald-500/50 shadow-inner' : 'text-slate-400 hover:text-white border-transparent'"
                >
                    <i class="fas fa-store mr-1.5 md:mr-2"></i> Nivel 3
                </button>
            </div>
        </div>

        <main
            class="flex-grow flex items-start justify-center p-4 md:p-6 relative z-10 w-full"
        >
            <div
                class="w-full max-w-6xl bg-slate-900/60 backdrop-blur-xl border border-slate-800 rounded-[2.5rem] p-6 md:p-10 shadow-2xl min-h-[600px]"
            >
                <div class="grid w-full">
                    <!-- CONTENIDO NIVEL 1 -->
                    <div
                        x-show="tab === 'l1'"
                        style="display: none"
                        class="col-start-1 row-start-1 w-full h-full"
                        x-transition:enter="transition ease-out duration-500 delay-100"
                        x-transition:enter-start="opacity-0 translate-y-4"
                        x-transition:enter-end="opacity-100 translate-y-0"
                        x-transition:leave="transition ease-in duration-300"
                        x-transition:leave-start="opacity-100"
                        x-transition:leave-end="opacity-0"
                    >
                        <header
                            class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6"
                        >
                            <div
                                class="font-black text-2xl md:text-3xl flex items-center gap-2 italic tracking-tighter text-white"
                            >
                                <i class="fas fa-rocket text-orange-500"></i> Nivel
                                <span
                                    class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-orange-600"
                                    >UNO</span
                                >
                            </div>
                            <div
                                class="border border-orange-500/50 bg-orange-500/10 text-orange-400 px-4 py-2 rounded-full font-black text-xs uppercase tracking-widest flex items-center gap-2"
                            >
                                <i class="fas fa-stopwatch"></i> ¡Web lista en 48
                                horas!
                            </div>
                        </header>
                        <div
                            class="w-full h-px bg-gradient-to-r from-slate-800 via-slate-700 to-slate-800 mb-8"
                        >
                        </div>
                        <div class="mb-10">
                            <h1
                                class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter mb-4 leading-tight text-white"
                            >
                                Web Presencia <br class="hidden md:block" />
                                <span
                                    class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-500"
                                    >Profesional</span
                                >
                            </h1>
                            <p
                                class="text-slate-400 font-medium text-lg max-w-2xl"
                            >
                                Impacta a tus clientes con una imagen digital
                                impecable.
                            </p>
                        </div>
                        <div
                            class="flex flex-col lg:grid lg:grid-cols-12 gap-8 mb-8"
                        >
                            <div
                                class="order-2 lg:order-1 lg:col-span-7 bg-slate-950/50 border border-slate-800/80 rounded-[2rem] p-6 md:p-8 grid grid-cols-1 sm:grid-cols-2 gap-6 content-start"
                            >
                                <div class="flex items-start gap-4">
                                    <div
                                        class="w-12 h-12 rounded-2xl bg-slate-900 border border-slate-800 flex items-center justify-center text-purple-400 shrink-0 shadow-inner"
                                    >
                                        <i class="fas fa-user-astronaut text-xl"
                                        ></i>
                                    </div>
                                    <div>
                                        <h3
                                            class="font-bold text-slate-200 text-sm md:text-base mb-1"
                                        >
                                            Identidad Digital
                                        </h3><p
                                            class="text-slate-400 text-xs md:text-sm leading-snug"
                                        >
                                            Ideal para marcas personales y
                                            perfiles profesionales.
                                        </p>
                                    </div>
                                </div>
                                <div class="flex items-start gap-4">
                                    <div
                                        class="w-12 h-12 rounded-2xl bg-slate-900 border border-slate-800 flex items-center justify-center text-yellow-500 shrink-0 shadow-inner"
                                    >
                                        <i class="fas fa-star text-xl"></i>
                                    </div>
                                    <div>
                                        <h3
                                            class="font-bold text-slate-200 text-sm md:text-base mb-1"
                                        >
                                            Diseño Inteligente
                                        </h3><p
                                            class="text-slate-400 text-xs md:text-sm leading-snug"
                                        >
                                            Estructura de una sola página
                                            diseñada para que tus servicios y
                                            trabajos se vean ordenados y
                                            profesionales.
                                        </p>
                                    </div>
                                </div>
                                <div class="flex items-start gap-4">
                                    <div
                                        class="w-12 h-12 rounded-2xl bg-slate-900 border border-slate-800 flex items-center justify-center text-pink-500 shrink-0 shadow-inner"
