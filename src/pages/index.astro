---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import { Image, Picture } from "astro:assets";
import Icon from "../components/Icon.astro";
import imgDoctor from "../assets/agencia-digital-diseno-web-doctor.webp";
import imgGym from "../assets/marketing-digital-gamarra-paginas-web.webp";
import imgMagnus from "../assets/servicio-pagina-web-peru-barato.webp";
import imgMockupL1 from "../assets/diseno-landing-page-profesional-doctor-lima.webp";
import imgMockupL2 from "../assets/pagina-web-corporativa-empresa-negocios.webp";
import imgMockupL3 from "../assets/tienda-online-virtual-ecommerce-carrito-de-compras-pagos.webp";
import imgHero1 from "../assets/diseno-web-clinicas-centros-medicos-lima.webp";
import imgHero2 from "../assets/pagina-web-portafolio-fotografos-profesionales.webp";
import imgHero4 from "../assets/creacion-web-gimnasios-fitness-peru.webp";
import imgHero5 from "../assets/diseno-web-empresas-construccion-ingenieria.webp";
import imgHero6 from "../assets/tienda-online-ecommerce-ropa-moda.webp";
---

<Layout
    title="Despega Tu Web | Tu negocio en Google esta semana"
    description="Creamos tu página web profesional en 48 horas. Rápida, segura y optimizada para convertir visitas en clientes reales."
>
    <style>
        .hero-mesh {
            background-color: #ffffff;
            background-image:
                radial-gradient(
                    at 0% 0%,
                    rgba(37, 99, 235, 0.08) 0px,
                    transparent 50%
                ),
                radial-gradient(
                    at 100% 0%,
                    rgba(99, 102, 241, 0.05) 0px,
                    transparent 50%
                ),
                radial-gradient(
                    at 100% 100%,
                    rgba(37, 99, 235, 0.08) 0px,
                    transparent 50%
                ),
                radial-gradient(
                    at 0% 100%,
                    rgba(99, 102, 241, 0.05) 0px,
                    transparent 50%
                );
        }

        @keyframes float {
            0% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-20px);
            }
            100% {
                transform: translateY(0px);
            }
        }
        @keyframes float-mobile {
            0% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-4px);
            }
            100% {
                transform: translateY(0px);
            }
        }
        .float-anim {
            animation: float-mobile 6s ease-in-out infinite;
        }
        @media (min-width: 1024px) {
            .float-anim {
                animation: float 6s ease-in-out infinite;
            }
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            shadow: 0 25px 50px -12px rgba(30, 58, 138, 0.12);
        }

        /* Hero Carousel */
        .hero-carousel-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            transition:
                opacity 0.9s ease-in-out,
                transform 1s ease-in-out;
            transform: scale(1);
        }
        .hero-carousel-img.active {
            opacity: 1;
            transform: scale(1);
        }
        .hero-carousel-img:hover {
            transform: scale(1);
        }
        .hero-bar-title {
            transition: opacity 0.4s ease;
        }
    </style>
    <Navbar />

    <!-- HERO SECTION: CRO PURO -->
    <section
        class="hero-mesh relative w-full pt-24 pb-4 sm:pt-24 sm:pb-8 overflow-hidden border-b border-slate-100"
    >
        <main
            class="max-w-7xl mx-auto px-6 flex flex-col items-start lg:grid lg:grid-cols-2 gap-3 lg:gap-12 lg:items-center relative z-10"
        >
            <!-- Parte 1: Texto (H1 y P) -->
            <div class="order-1 animate-in fade-in slide-in-from-left duration-1000 w-full">
                <div
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 text-[10px] sm:text-xs font-bold uppercase tracking-widest mb-4 sm:mb-8 shadow-sm"
                >
                    <span class="relative flex h-2 w-2">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-green-500"
                        ></span>
                    </span>
                    Agencia de Desarrollo Web
                </div>

                <h1
                    class="text-5xl md:text-8xl font-black leading-[0.95] mb-4 sm:mb-8 text-slate-950 tracking-tight"
                >
                    Tu negocio <br />
                    <span class="text-blue-600">en Google</span>
                    <br />
                    esta semana
                </h1>

                <p
                    class="text-xl text-slate-700 leading-relaxed mb-1 sm:mb-10 max-w-lg font-medium"
                >
                    Creamos tu página web profesional. Rápida, segura y
                    optimizada para conseguir más clientes y contactos reales.
                </p>
            </div>

            <!-- Parte 2: Bloque Visual (Carrusel) - Aparece después del texto en móvil -->
            <div
                class="order-2 relative animate-in fade-in slide-in-from-right duration-1000 delay-200 lg:row-span-2 w-full mb-10 lg:mb-0"
            >
                <div
                    class="glass-card p-4 rounded-[2.5rem] shadow-2xl float-anim"
                >
                    <div
                        class="bg-white rounded-[1.8rem] overflow-hidden flex flex-col group border border-slate-200 shadow-2xl shadow-blue-900/10"
                    >
                        <!-- Barra de Título Superior -->
                        <div
                            class="bg-white p-3 px-5 flex items-center justify-between border-b border-slate-100 relative z-20"
                        >
                            <div class="flex items-center gap-3">
                                <div class="flex gap-1.5">
                                    <div
                                        class="w-2.5 h-2.5 rounded-full bg-blue-600 shadow-sm shadow-blue-200"
                                    >
                                    </div>
                                    <div
                                        class="w-2.5 h-2.5 rounded-full bg-blue-200"
                                    >
                                    </div>
                                </div>
                                <div
                                    id="hero-bar-title"
                                    class="text-slate-900 font-black uppercase text-[10px] tracking-widest border-l border-slate-100 pl-3 hero-bar-title"
                                >
                                    CENTRO MÉDICO
                                </div>
                            </div>
                            <!-- Dots indicator -->
                            <div class="flex gap-1.5" id="hero-dots">
                                <button
                                    data-idx="0"
                                    class="hero-dot w-1.5 h-1.5 rounded-full bg-blue-600 transition-all"
                                ></button>
                                <button
                                    data-idx="1"
                                    class="hero-dot w-1.5 h-1.5 rounded-full bg-slate-300 transition-all"
                                ></button>
                                <button
                                    data-idx="2"
                                    class="hero-dot w-1.5 h-1.5 rounded-full bg-slate-300 transition-all"
                                ></button>
                                <button
                                    data-idx="3"
                                    class="hero-dot w-1.5 h-1.5 rounded-full bg-slate-300 transition-all"
                                ></button>
                            </div>
                        </div>

                        <!-- Contenedor de Carrusel -->
                        <div
                            class="relative w-full aspect-[4/3] overflow-hidden bg-slate-50"
                        >
                            <Picture
                                src={imgHero2}
                                alt="Landing page tipo portafolio optimizada para fotógrafos y creativos."
                                widths={[400, 800]}
                                width={800}
                                height={600}
                                formats={["avif", "webp"]}
                                sizes="(max-width: 768px) calc(100vw - 48px), 600px"
                                class="hero-carousel-img active"
                                loading="eager"
                                fetchpriority="high"
                            />
                            <Picture
                                src={imgHero5}
                                alt="Página web corporativa para empresas de construcción, proyectos e ingeniería."
                                widths={[400, 800]}
                                width={800}
                                height={600}
                                formats={["avif", "webp"]}
                                sizes="(max-width: 768px) calc(100vw - 48px), 600px"
                                class="hero-carousel-img"
                                loading="lazy"
                            />
                            <Picture
                                src={imgHero1}
                                alt="Diseño de página web profesional para clínicas y centros médicos con reserva de citas."
                                widths={[400, 800]}
                                width={800}
                                height={600}
                                formats={["avif", "webp"]}
                                sizes="(max-width: 768px) calc(100vw - 48px), 600px"
                                class="hero-carousel-img"
                                loading="lazy"
                            />
                            <Picture
                                src={imgHero6}
                                alt="E-commerce profesional para marcas de ropa con pasarela de pagos integrada."
                                widths={[400, 800]}
                                width={800}
                                height={600}
                                formats={["avif", "webp"]}
                                sizes="(max-width: 768px) calc(100vw - 48px), 600px"
                                class="hero-carousel-img"
                                loading="lazy"
                            />
                        </div>
                    </div>
                    <script>
                        const images =
                            document.querySelectorAll(".hero-carousel-img");
                        const dots = document.querySelectorAll(".hero-dot");
                        const titleEl =
                            document.getElementById("hero-bar-title");
                        const titles = [
                            "SOL & ALMA",
                            "CONSTRUCCIONES VANGUARDIA",
                            "MEDICLINICAS",
                            "VELVET & THREAD",
                        ];
                        let idx = 0;
                        const rotate = () => {
                            images.forEach((img, i) => {
                                img.classList.toggle("active", i === idx);
                            });
                            dots.forEach((dot, i) => {
                                dot.classList.toggle("bg-blue-600", i === idx);
                                dot.classList.toggle("bg-slate-300", i !== idx);
                            });
                            if (titleEl) titleEl.textContent = titles[idx];
                            idx = (idx + 1) % images.length;
                        };
                        // Initial state
                        rotate();
                        setInterval(rotate, 4000);
                    </script>
                </div>

                <div
                    class="absolute -bottom-6 -left-6 glass-card px-5 py-3 rounded-2xl shadow-xl flex items-center gap-3 border border-slate-100"
                >
                    <div class="p-2 bg-green-100 rounded-lg text-green-600">
                        <Icon name="fa6-solid:check" class="text-lg" />
                    </div>
                    <div
                        class="text-[10px] font-black uppercase tracking-widest text-slate-700"
                    >
                        99.9% Speed Score
                    </div>
                </div>
            </div>

            <!-- Parte 3: CTA (Botón y Estrellas) - Aparece al final en móvil -->
            <div class="order-3 animate-in fade-in slide-in-from-left duration-1000 delay-100">
                <div
                    class="flex flex-col sm:flex-row gap-5 items-start sm:items-center"
                >
                    <a
                        href="https://wa.me/51963896469"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-full sm:w-auto px-8 py-5 bg-blue-600 text-white rounded-2xl font-black text-sm md:text-base uppercase tracking-widest shadow-xl shadow-blue-600/30 hover:bg-blue-700 hover:-translate-y-1 transition-all text-center flex items-center justify-center gap-2"
                    >
                        <Icon name="fa6-brands:whatsapp" class="text-xl" />
                        Quiero mi Web — S/ 450
                    </a>

                    <div class="flex items-center gap-3 px-2 py-2">
                        <div class="flex gap-0.5 text-yellow-400 text-lg">
                            ★<span class="hidden sm:inline">★</span>★<span
                                class="hidden sm:inline">★</span
                            >★
                        </div>
                        <p
                            class="text-[11px] font-bold text-slate-500 leading-tight uppercase tracking-tighter border-l border-slate-300 pl-3"
                        >
                            Respaldado por <br />
                            negocios locales.
                        </p>
                    </div>
                </div>
            </div>
        </main>

        <!-- Footer de ROI integrado -->
        <div
            class="max-w-7xl mx-auto px-6 border-t border-slate-200 py-8 grid grid-cols-2 sm:grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 mt-4 md:mt-8 relative z-10"
        >
            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 shrink-0"
                >
                    <Icon
                        name="fa6-solid:hand-holding-dollar"
                        class="text-xl"
                    />
                </div>
                <div>
                    <p
                        class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-0.5"
                    >
                        Un Solo Pago
                    </p>
                    <p class="text-lg font-bold text-slate-800 leading-tight">
                        Desde S/ 450
                    </p>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 shrink-0"
                >
                    <Icon name="fa6-solid:bolt" class="text-xl" />
                </div>
                <div>
                    <p
                        class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-0.5"
                    >
                        Entrega Rápida
                    </p>
                    <p class="text-lg font-bold text-slate-800 leading-tight">
                        48 Horas
                    </p>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 shrink-0"
                >
                    <Icon name="fa6-solid:location-dot" class="text-xl" />
                </div>
                <div>
                    <p
                        class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-0.5"
                    >
                        Soporte en Perú
                    </p>
                    <p class="text-lg font-bold text-slate-800 leading-tight">
                        Lima, Perú
                    </p>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 shrink-0"
                >
                    <Icon
                        name="fa6-solid:mobile-screen-button"
                        class="text-xl"
                    />
                </div>
                <div>
                    <p
                        class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-0.5"
                    >
                        Tu Web en el Celular
                    </p>
                    <p class="text-lg font-bold text-slate-800 leading-tight">
                        Perfecto en Celulares
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- TIPOS DE WEB -->
    <section
        id="tipos-de-web"
        class="relative py-10 md:py-24 px-6 bg-slate-50 border-b border-slate-200"
    >
        <!-- Soft Radial Glow -->
        <div
            class="absolute top-0 right-0 w-96 h-96 bg-blue-100/40 rounded-full blur-3xl pointer-events-none -z-10"
        >
        </div>

        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-8 md:mb-16">
                <h2
                    class="text-3xl md:text-5xl font-black tracking-tighter uppercase italic text-slate-900 mb-6"
                >
                    Encuentra tu nivel de
                    <span class="text-blue-600">despegue</span>
                </h2>
                <p
                    class="text-slate-500 font-bold uppercase tracking-[0.2em] text-xs"
                >
                    Selecciona la etapa actual de tu negocio en el mercado
                    digital
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
                <!-- Nivel 1 -->
                <div
                    class="flex flex-col h-full bg-white rounded-[2.5rem] p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all group"
                >
                    <div class="mb-6 px-2">
                        <span
                            class="text-blue-600 font-black text-xs uppercase tracking-[0.2em]"
                            >Nivel 1</span
                        >
                        <h3
                            class="text-xl font-black text-slate-900 uppercase italic mt-1"
                        >
                            Identidad Digital
                        </h3>
                    </div>
                    <div
                        class="w-full h-44 bg-slate-100 rounded-[1.8rem] mb-6 overflow-hidden relative shrink-0 border border-slate-100"
                    >
                        <Picture
                            src={imgMockupL1}
                            alt="Mockup L1"
                            widths={[300, 500]}
                            formats={["avif", "webp"]}
                            sizes="(max-width: 768px) calc(100vw - 48px), 280px"
                            width={500}
                            height={333}
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                            loading="lazy"
                        />
                    </div>
                    <div class="space-y-4 mb-4 grow flex flex-col px-2">
                        <div
                            class="bg-slate-50 p-4 rounded-2xl border border-slate-200 min-h-[115px]"
                        >
                            <p
                                class="text-[10px] font-black text-blue-600 uppercase mb-2"
                            >
                                ¿Es para mí?
                            </p>
                            <p class="text-sm text-slate-600 leading-snug">
                                Si eres un <strong class="text-slate-900"
                                    >profesional independiente o emprendedor</strong
                                > que desea una <strong class="text-slate-900"
                                    >presencia oficial</strong
                                > para que sus clientes potenciales lo encuentren
                                rápido en Google.
                            </p>
                        </div>
                        <div
                            class="bg-white p-4 rounded-2xl border border-dashed border-slate-300"
                        >
                            <p
                                class="text-[10px] font-black text-slate-500 uppercase mb-2"
                            >
                                ¿Qué ofrece?
                            </p>
                            <ul class="text-xs text-slate-600 space-y-2">
                                <li class="flex items-center">
                                    <Icon
                                        name="fa6-solid:check"
                                        class="text-blue-600 mr-2"
                                    />1 Sección (Landing Page)
                                </li>
                                <li class="flex items-center">
                                    <Icon
                                        name="fa6-solid:check"
                                        class="text-blue-600 mr-2"
                                    />Entrega en 48 Horas
                                </li>
                                <li class="flex items-center">
                                    <Icon
                                        name="fa6-solid:check"
                                        class="text-blue-600 mr-2"
                                    />Botón Directo WhatsApp
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="mt-auto shrink-0 flex flex-col gap-4">
                        <div
                            class="flex justify-between items-center bg-slate-50 px-5 py-4 rounded-2xl border border-slate-200"
                        >
                            <span
                                class="text-slate-500 font-bold text-[10px] uppercase tracking-widest"
                                >Plan 1</span
                            >
                            <span
                                class="text-slate-900 font-black text-xl italic"
                                >S/ 450</span
                            >
                        </div>
                        <a
                            href="/planes#l1"
                            class="w-full py-4 bg-blue-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest text-center hover:bg-blue-700 transition-all shadow-md shadow-blue-200"
                        >
                            Ver detalles del Nivel 1
                        </a>
                    </div>
                </div>

                <!-- Nivel 2 -->
                <div
                    class="flex flex-col h-full bg-white rounded-[2.5rem] p-6 border border-blue-100 shadow-md hover:shadow-lg transition-all group relative"
                >
                    <div
                        class="absolute -top-3 left-1/2 -translate-x-1/2 bg-blue-600 text-white text-[9px] font-black uppercase px-4 py-1 rounded-full tracking-widest"
                    >
                        MÁS SOLICITADO
                    </div>
                    <div class="mb-6 px-2">
                        <span
                            class="text-blue-600 font-black text-xs uppercase tracking-[0.2em]"
                            >Nivel 2</span
                        >
                        <h3
                            class="text-xl font-black text-slate-900 uppercase italic mt-1"
                        >
                            Poder Corporativo
                        </h3>
                    </div>
                    <div
                        class="w-full h-44 bg-slate-100 rounded-[1.8rem] mb-6 overflow-hidden relative shrink-0 border border-slate-100"
                    >
                        <Picture
                            src={imgMockupL2}
                            alt="Mockup L2"
                            widths={[300, 500]}
                            formats={["avif", "webp"]}
                            sizes="(max-width: 768px) calc(100vw - 48px), 280px"
                            width={500}
                            height={333}
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                            loading="lazy"
                        />
                    </div>
                    <div class="space-y-4 mb-4 grow flex flex-col px-2">
                        <div
                            class="bg-blue-50 p-4 rounded-2xl border border-blue-100 min-h-[115px]"
                        >
                            <p
                                class="text-[10px] font-black text-blue-600 uppercase mb-2"
                            >
                                ¿Es para mí?
                            </p>
                            <p class="text-sm text-slate-600 leading-snug">
                                Si tienes una <strong class="text-slate-900"
                                    >empresa de servicios</strong
                                > que busca proyectar <strong
                                    class="text-slate-900"
                                    >estatus de élite</strong
                                > y necesitas autonomía para gestionar tus propios
                                contenidos.
                            </p>
                        </div>
                        <div
                            class="bg-white p-4 rounded-2xl border border-dashed border-slate-300"
                        >
                            <p
                                class="text-[10px] font-black text-slate-500 uppercase mb-2"
                            >
                                ¿Qué ofrece?
                            </p>
                            <ul class="text-xs text-slate-600 space-y-2">
                                <li class="flex items-center">
                                    <Icon
                                        name="fa6-solid:check"
                                        class="text-blue-600 mr-2"
                                    />Hasta 5 Secciones Pro
                                </li>
                                <li class="flex items-center">
                                    <Icon
                                        name="fa6-solid:check"
                                        class="text-blue-600 mr-2"
                                    />Panel de Control (CMS)
                                </li>
                                <li class="flex items-center">
                                    <Icon
                                        name="fa6-solid:check"
                                        class="text-blue-600 mr-2"
                                    />Correos Corporativos
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="mt-auto shrink-0 flex flex-col gap-4">
                        <div
                            class="flex justify-between items-center bg-slate-50 px-5 py-4 rounded-2xl border border-slate-200"
                        >
                            <span
                                class="text-slate-500 font-bold text-[10px] uppercase tracking-widest"
                                >Plan 2</span
                            >
                            <span
                                class="text-slate-900 font-black text-xl italic"
                                >S/ 1,000</span
                            >
                        </div>
                        <a
                            href="/planes#l2"
                            class="w-full py-4 bg-blue-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest text-center hover:bg-blue-700 transition-all shadow-md shadow-blue-200"
                        >
                            Ver detalles del Nivel 2
                        </a>
                    </div>
                </div>

                <!-- Nivel 3 -->
                <div
                    class="flex flex-col h-full bg-white rounded-[2.5rem] p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all group"
                >
                    <div class="mb-6 px-2">
                        <span
                            class="text-emerald-600 font-black text-xs uppercase tracking-[0.2em]"
                            >Nivel 3</span
                        >
                        <h3
                            class="text-xl font-black text-slate-900 uppercase italic mt-1"
                        >
                            Ventas 24/7
                        </h3>
                    </div>
                    <div
                        class="w-full h-44 bg-slate-100 rounded-[1.8rem] mb-6 overflow-hidden relative shrink-0 border border-slate-100"
