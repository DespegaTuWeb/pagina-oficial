---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
---

<Layout
    title="DespegaTuWeb | Creación de Páginas Web para Emprendedores, Negocios y Empresas"
    description="Creamos la página web de tu negocio para que tus clientes te encuentren rápido. Páginas modernas, seguras y profesionales para vender más."
>
    <Navbar />

    <section
        class="relative w-full md:min-h-[100svh] overflow-x-hidden overflow-y-auto md:overflow-hidden bg-slate-950 border-b border-slate-800"
        x-data="{ showWelcome: false, showExtra: false, isUp: false, activeCard: 0 }"
        x-init="setTimeout(() => showWelcome = true, 200); setTimeout(() => isUp = true, 2800); setTimeout(() => showExtra = true, 4500);"
    >
        <div
            class="absolute left-0 w-full z-0 overflow-hidden pointer-events-none transition-all duration-500 top-20 aspect-video md:top-0 md:aspect-auto md:h-full"
        >
            <video
                id="hero-video"
                autoplay
                muted
                loop
                playsinline
                preload="auto"
                poster="/imgs/hero-fallback.webp"
                class="w-full h-full object-cover md:object-contain md:object-center opacity-100 md:opacity-40 transition-opacity"
            >
                <source src="/imgs/hero-fallback.webp" type="video/webm" />
                <source src="/imgs/hero.mp4" type="video/mp4" />
            </video>
            <div
                class="hidden md:block absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-transparent z-[1]"
            >
            </div>
        </div>

        <div
            class="relative z-10 w-full md:min-h-[100svh] max-w-5xl mx-auto px-4 md:px-6 flex flex-col items-center pt-20 pb-8 md:pt-28 md:pb-12 gap-6 md:gap-12 md:justify-center"
        >
            <div
                class="w-full z-20 flex flex-col items-center justify-center aspect-video md:aspect-auto md:h-auto"
                x-show="showWelcome"
                style="display: none"
                x-transition:enter="transition ease-out duration-800"
                x-transition:enter-start="opacity-0"
                x-transition:enter-end="opacity-100"
            >
                <div
                    class="w-full h-full flex md:hidden flex-col items-center justify-start pt-6 sm:pt-8 px-1"
                    x-data="{ baseText: '¡HOLA! BIENVENIDO A LA AGENCIA #1 DE LIMA', baseTyped: '', baseChar: 0, phrases:['EN DESARROLLO WEB', 'EN LANDING PAGES', 'EN PÁGINAS CORPORATIVAS', 'EN TIENDAS ONLINE'], phraseIdx: 0, loopTyped: '', loopChar: 0, isDeleting: false, startLoop() { let current = this.phrases[this.phraseIdx]; if(this.isDeleting) { this.loopTyped = current.substring(0, this.loopChar - 1); this.loopChar--; } else { this.loopTyped = current.substring(0, this.loopChar + 1); this.loopChar++; } let speed = this.isDeleting ? 30 : 60; if(!this.isDeleting && this.loopChar === current.length) { speed = 2000; this.isDeleting = true; } else if(this.isDeleting && this.loopChar === 0) { this.isDeleting = false; this.phraseIdx = (this.phraseIdx + 1) % this.phrases.length; speed = 500; } setTimeout(() => { this.startLoop() }, speed); }, typeBase() { if(this.baseChar < this.baseText.length) { this.baseTyped += this.baseText.charAt(this.baseChar); this.baseChar++; setTimeout(() => { this.typeBase() }, 35); } else { setTimeout(() => { this.startLoop() }, 500); } } }"
                    x-init="setTimeout(() => { typeBase() }, 800)"
                >
                    <h2
                        class="font-black uppercase italic tracking-wide text-[9px] min-[380px]:text-[10px] sm:text-xs text-center leading-relaxed"
                    >
                        <span
                            class="text-white drop-shadow-lg"
                            x-text="baseTyped"></span>
                        <br />
                        <div class="mt-1 h-4 flex items-center justify-center">
                            <span
                                class="text-blue-500 drop-shadow-lg"
                                x-show="baseChar >= baseText.length"
                            >
                                <span x-text="loopTyped"></span><span
                                    class="animate-pulse text-white">|</span
                                >
                            </span>
                        </div>
                    </h2>
                </div>

                <div
                    class="hidden md:block w-full text-center transition-all duration-[3000ms] ease-in-out transform origin-center px-4"
                    :class="isUp ? 'scale-[0.80] translate-y-0' : 'scale-100 translate-y-[15vh]'"
                >
                    <h2
                        class="font-black uppercase italic tracking-tighter drop-shadow-2xl leading-none transition-all duration-[3000ms]"
                        x-data="{ fill: false, glow: false }"
                        x-init="setTimeout(() => fill = true, 600); setTimeout(() => glow = true, 1800);"
                    >
                        <span
                            class="block transition-all duration-[3000ms] text-lg md:text-2xl text-white"
                            :class="isUp ? 'opacity-50 mb-1' : 'opacity-80 mb-2'"
                        >
                            ¡Hola! Bienvenido a
                        </span>
                        <span
                            class="relative inline-block my-2 transition-all duration-[3000ms] ease-in-out text-3xl sm:text-5xl md:text-7xl"
                        >
                            <span
                                class="relative inline-block transition-all duration-[1000ms]"
                                :class="glow ? 'drop-shadow-[0_0_35px_rgba(59,130,246,1)] brightness-125' : ''"
                            >
                                <span
                                    class="block text-transparent pointer-events-none"
                                    style="-webkit-text-stroke: 1px rgba(59, 130, 246, 0.5);"
                                >
                                    la agencia #1 de Lima
                                </span>
                                <span
                                    class="absolute inset-0 text-blue-500 pointer-events-none"
                                    style="transition: clip-path 1200ms ease-out;"
                                    :style="fill ? 'clip-path: inset(0 0 0 0);' : 'clip-path: inset(0 100% 0 0);'"
                                >
                                    la agencia #1 de Lima
                                </span>
                            </span>
                        </span>
                        <span
                            class="block transition-all duration-[3000ms] text-lg md:text-2xl text-white"
                            :class="isUp ? 'opacity-50 mt-1' : 'opacity-80 mt-2'"
                        >
                            en desarrollo web
                        </span>
                    </h2>
                </div>
            </div>

            <div
                class="w-full flex flex-col items-center gap-3 md:gap-12 z-10 mt-2 md:mt-0"
            >
                <div
                    class="w-full flex justify-center opacity-100 translate-y-0 md:opacity-0 md:translate-y-8 md:pointer-events-none md:transition-all md:ease-out md:duration-1000 md:delay-[200ms]"
                    :class="showExtra ? 'md:opacity-100 md:translate-y-0 md:pointer-events-auto' : ''"
                >
                    <div
                        x-data="{ x: 0, y: 0 }"
                        @mousemove="x = $event.offsetX; y = $event.offsetY"
                        class="relative backdrop-blur-xl bg-white/5 border border-white/20 p-4 md:p-6 rounded-[1.5rem] md:rounded-[2.5rem] shadow-[0_8px_32px_0_rgba(0,0,0,0.8)] max-w-2xl w-full text-left md:text-center group overflow-hidden"
                    >
                        <div
                            class="absolute -top-24 -left-24 w-48 md:w-64 h-48 md:h-64 bg-blue-600/20 rounded-full blur-[60px] md:blur-[80px] animate-pulse pointer-events-none"
                        >
                        </div>
                        <div
                            class="absolute -bottom-24 -right-24 w-48 md:w-64 h-48 md:h-64 bg-purple-600/15 rounded-full blur-[60px] md:blur-[80px] animate-pulse delay-700 pointer-events-none"
                        >
                        </div>

                        <div
                            class="absolute inset-0 opacity-[0.05] pointer-events-none"
                            style="background-image: url('https://grainy-gradients.vercel.app/noise.svg'); filter: contrast(150%) brightness(100%);"
                        >
                        </div>
                        <div
                            class="absolute inset-0 pointer-events-none transition-opacity duration-500 opacity-0 group-hover:opacity-100"
                            :style="`background: radial-gradient(600px circle at ${x}px ${y}px, rgba(59,130,246,0.12), transparent 40%);`"
                        >
                        </div>
                        <div
                            class="absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent pointer-events-none"
                        >
                        </div>

                        <div
                            class="relative z-10 flex flex-col md:items-center"
                        >
                            <div
                                class="bg-blue-600 text-white text-[9px] md:text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest mb-2 md:mb-4 inline-block shadow-lg shadow-blue-900/50 w-max"
                            >
                                Tu marca en todo el mundo111
                            </div>
                            <h3
                                class="text-white text-lg md:text-3xl font-black italic uppercase leading-tight mb-1 md:mb-3 drop-shadow-md"
                            >
                                Tu negocio siempre activo
                            </h3>
                            <p
                                class="text-slate-300 text-xs md:text-base font-medium leading-relaxed max-w-lg md:mx-auto"
                            >
                                Desarrollamos páginas web para marcas
                                personales, negocios, empresas y comercios
                            </p>
                        </div>
                    </div>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-6 w-full max-w-4xl px-2"
                >
                    <div
                        class="h-full opacity-100 translate-y-0 md:opacity-0 md:translate-y-6 md:pointer-events-none md:transition-all md:ease-out md:duration-700 md:delay-[600ms]"
                        :class="showExtra ? 'md:opacity-100 md:translate-y-0 md:pointer-events-auto' : ''"
                    >
                        <div
                            @click="activeCard = 1"
                            class="flex flex-row md:flex-col items-center md:justify-center text-left md:text-center gap-3 md:gap-4 backdrop-blur-md bg-black/40 border p-3 md:p-6 rounded-2xl md:rounded-[2rem] transition-all duration-500 cursor-pointer h-auto md:h-[210px] group border-purple-500/40 shadow-[0_0_20px_rgba(168,85,247,0.15)] w-full"
                            :class="activeCard === 1 ? 'border-purple-400 shadow-[0_0_40px_rgba(168,85,247,0.5)] brightness-125 scale-[1.02]' : ''"
                        >
                            <div
                                class="w-10 h-10 md:w-16 md:h-16 rounded-xl md:rounded-2xl bg-indigo-500/20 flex items-center justify-center text-indigo-400 shrink-0 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3 group-hover:bg-indigo-500/30 shadow-inner"
                            >
                                <i
                                    class="fas fa-file-signature text-base md:text-2xl"
                                ></i>
                            </div>
                            <div class="flex flex-col mt-0 md:mt-2">
                                <span
                                    class="text-white text-sm md:text-base font-black uppercase tracking-wider mb-0 md:mb-2"
                                    >Emitimos Boleta</span
                                >
                                <span
                                    class="text-slate-400 text-[10px] md:text-xs leading-snug md:px-2"
                                    >Formalidad legal garantizada para tu
                                    inversión</span
                                >
                            </div>
                        </div>
                    </div>

                    <div
                        class="h-full opacity-100 translate-y-0 md:opacity-0 md:translate-y-6 md:pointer-events-none md:transition-all md:ease-out md:duration-700 md:delay-[800ms]"
                        :class="showExtra ? 'md:opacity-100 md:translate-y-0 md:pointer-events-auto' : ''"
                    >
                        <div
                            @click="activeCard = 2"
                            class="flex flex-row md:flex-col items-center md:justify-center text-left md:text-center gap-3 md:gap-4 backdrop-blur-md bg-blue-600/20 border p-3 md:p-6 rounded-2xl md:rounded-[2rem] transition-all duration-500 cursor-pointer h-auto md:h-[210px] group border-blue-500/40 shadow-[0_0_20px_rgba(59,130,246,0.2)] w-full"
                            :class="activeCard === 2 ? 'border-blue-400 shadow-[0_0_40px_rgba(59,130,246,0.6)] brightness-125 scale-[1.02]' : ''"
                        >
                            <div
                                class="w-10 h-10 md:w-16 md:h-16 rounded-xl md:rounded-2xl bg-blue-600 flex items-center justify-center text-white shrink-0 transition-transform duration-500 group-hover:scale-110 group-hover:-rotate-3 shadow-[0_0_20px_rgba(59,130,246,0.5)]"
                            >
                                <i
                                    class="fas fa-bolt-lightning text-base md:text-2xl"
                                ></i>
                            </div>
                            <div class="flex flex-col mt-0 md:mt-2">
                                <span
                                    class="text-white text-sm md:text-base font-black uppercase tracking-wider mb-0 md:mb-2"
                                    >Desde S/ 450</span
                                >
                                <span
                                    class="text-blue-100 text-[10px] md:text-xs leading-snug md:px-2"
                                    >Tu marca profesional al mejor precio del
                                    mercado</span
                                >
                            </div>
                        </div>
                    </div>

                    <div
                        class="h-full opacity-100 translate-y-0 md:opacity-0 md:translate-y-6 md:pointer-events-none md:transition-all md:ease-out md:duration-700 md:delay-[1000ms]"
                        :class="showExtra ? 'md:opacity-100 md:translate-y-0 md:pointer-events-auto' : ''"
                    >
                        <div
                            @click="activeCard = 3"
                            class="flex flex-row md:flex-col items-center md:justify-center text-left md:text-center gap-3 md:gap-4 backdrop-blur-md bg-black/40 border p-3 md:p-6 rounded-2xl md:rounded-[2rem] transition-all duration-500 cursor-pointer h-auto md:h-[210px] group border-emerald-500/40 shadow-[0_0_20px_rgba(16,185,129,0.15)] w-full"
                            :class="activeCard === 3 ? 'border-emerald-400 shadow-[0_0_40px_rgba(16,185,129,0.5)] brightness-125 scale-[1.02]' : ''"
                        >
                            <div
                                class="w-10 h-10 md:w-16 md:h-16 rounded-xl md:rounded-2xl bg-cyan-500/20 flex items-center justify-center text-cyan-400 shrink-0 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3 group-hover:bg-emerald-500/30 shadow-inner"
                            >
                                <i
                                    class="fas fa-check-double text-base md:text-2xl"
                                ></i>
                            </div>
                            <div class="flex flex-col mt-0 md:mt-2">
                                <span
                                    class="text-white text-sm md:text-base font-black uppercase tracking-wider mb-0 md:mb-2"
                                    >Cero Costos</span
                                >
                                <span
                                    class="text-slate-400 text-[10px] md:text-xs leading-snug md:px-2"
                                    >Sin mensualidades trampa. La web es 100%
                                    tuya</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- TIPOS DE WEB -->
    <section
        id="tipos-de-web"
        class="py-10 md:py-24 px-6 bg-slate-950 border-b border-slate-800"
    >
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-8 md:mb-16">
                <h2
                    class="text-3xl md:text-5xl font-black tracking-tighter uppercase italic text-white mb-6"
                >
                    Encuentra tu nivel de
                    <span class="text-blue-500">despegue</span>
                </h2>
                <p
                    class="text-slate-400 font-bold uppercase tracking-[0.2em] text-xs"
                >
                    Selecciona la etapa actual de tu negocio en el mercado
                    digital
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
                <!-- Nivel 1 -->
                <div
                    class="flex flex-col h-full bg-slate-900/50 rounded-[2.5rem] p-6 border border-slate-800 hover:border-blue-500/50 transition-all group"
                >
                    <div class="mb-6 px-2">
                        <span
                            class="text-blue-500 font-black text-xs uppercase tracking-[0.2em]"
                            >Nivel 1</span
                        >
                        <h3
                            class="text-xl font-black text-white uppercase italic mt-1"
                        >
                            Identidad Digital
                        </h3>
                    </div>
                    <div
                        class="w-full h-44 bg-slate-800 rounded-[1.8rem] mb-6 overflow-hidden relative shrink-0 border border-white/5"
                    >
                        <img
                            src="/imgs/diseno-landing-page-profesional-doctor-lima.webp"
                            alt="Mockup L1"
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                        />
                    </div>
                    <div class="space-y-4 mb-4 grow flex flex-col px-2">
                        <div
                            class="bg-slate-800/40 p-4 rounded-2xl border border-slate-700/50 min-h-[115px]"
                        >
                            <p
                                class="text-[10px] font-black text-blue-400 uppercase mb-2"
                            >
                                ¿Es para mí?
                            </p>
                            <p class="text-sm text-slate-300 leading-snug">
                                Si eres un <strong
                                    >profesional independiente o emprendedor</strong
                                > que desea una <strong
                                    >presencia oficial</strong
                                > para que sus clientes potenciales lo encuentren
                                rápido en Google.
                            </p>
                        </div>
                        <div
                            class="bg-slate-800/20 p-4 rounded-2xl border border-dashed border-slate-700/50"
                        >
                            <p
                                class="text-[10px] font-black text-slate-500 uppercase mb-2"
                            >
                                ¿Qué ofrece?
                            </p>
                            <ul class="text-xs text-slate-400 space-y-2">
                                <li>
                                    <i class="fas fa-check text-blue-500 mr-2"
                                    ></i>1 Sección (Landing Page)
                                </li>
                                <li>
                                    <i class="fas fa-check text-blue-500 mr-2"
                                    ></i>Entrega en 48 Horas
                                </li>
                                <li>
                                    <i class="fas fa-check text-blue-500 mr-2"
                                    ></i>Botón Directo WhatsApp
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="mt-auto shrink-0 flex flex-col gap-4">
                        <div
                            class="flex justify-between items-center bg-slate-950 px-5 py-4 rounded-2xl border border-slate-800"
                        >
                            <span
                                class="text-slate-400 font-bold text-[10px] uppercase tracking-widest"
                                >Plan 1</span
                            >
                            <span class="text-white font-black text-xl italic"
                                >S/ 450</span
                            >
                        </div>
                        <a
                            href="/planes#l1"
                            class="w-full py-4 bg-blue-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest text-center hover:bg-blue-500 transition-all"
                        >
                            Ver detalles del Nivel 1
                        </a>
                    </div>
                </div>

                <!-- Nivel 2 -->
                <div
                    class="flex flex-col h-full bg-slate-900/50 rounded-[2.5rem] p-6 border border-blue-500/30 shadow-[0_0_30px_rgba(59,130,246,0.1)] hover:border-blue-500/50 transition-all group relative"
                >
                    <div
                        class="absolute -top-3 left-1/2 -translate-x-1/2 bg-blue-600 text-white text-[9px] font-black uppercase px-4 py-1 rounded-full tracking-widest"
                    >
                        MÁS SOLICITADO
                    </div>
                    <div class="mb-6 px-2">
                        <span
                            class="text-blue-500 font-black text-xs uppercase tracking-[0.2em]"
                            >Nivel 2</span
                        >
                        <h3
                            class="text-xl font-black text-white uppercase italic mt-1"
                        >
                            Poder Corporativo
                        </h3>
                    </div>
                    <div
                        class="w-full h-44 bg-slate-800 rounded-[1.8rem] mb-6 overflow-hidden relative shrink-0 border border-white/5"
                    >
                        <img
                            src="/imgs/pagina-web-corporativa-empresa-negocios.webp"
                            alt="Mockup L2"
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                        />
                    </div>
                    <div class="space-y-4 mb-4 grow flex flex-col px-2">
                        <div
                            class="bg-blue-900/20 p-4 rounded-2xl border border-blue-500/20 min-h-[115px]"
                        >
                            <p
                                class="text-[10px] font-black text-blue-400 uppercase mb-2"
                            >
                                ¿Es para mí?
                            </p>
                            <p class="text-sm text-slate-300 leading-snug">
                                Si tienes una <strong
                                    >empresa de servicios</strong
                                > que busca proyectar <strong
                                    >estatus de élite</strong
                                > y necesitas autonomía para gestionar tus propios
                                contenidos.
                            </p>
                        </div>
                        <div
                            class="bg-slate-800/20 p-4 rounded-2xl border border-dashed border-slate-700/50"
                        >
                            <p
                                class="text-[10px] font-black text-slate-500 uppercase mb-2"
                            >
                                ¿Qué ofrece?
                            </p>
                            <ul class="text-xs text-slate-400 space-y-2">
                                <li>
                                    <i class="fas fa-check text-blue-400 mr-2"
                                    ></i>Hasta 5 Secciones Pro
                                </li>
                                <li>
                                    <i class="fas fa-check text-blue-400 mr-2"
                                    ></i>Panel de Control (CMS)
                                </li>
                                <li>
                                    <i class="fas fa-check text-blue-400 mr-2"
                                    ></i>Correos Corporativos
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="mt-auto shrink-0 flex flex-col gap-4">
                        <div
                            class="flex justify-between items-center bg-slate-950 px-5 py-4 rounded-2xl border border-slate-800"
                        >
                            <span
                                class="text-slate-400 font-bold text-[10px] uppercase tracking-widest"
                                >Plan 2</span
                            >
                            <span class="text-white font-black text-xl italic"
                                >S/ 1,000</span
                            >
                        </div>
                        <a
                            href="/planes#l2"
                            class="w-full py-4 bg-blue-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest text-center hover:bg-blue-500 transition-all"
                        >
                            Ver detalles del Nivel 2
                        </a>
                    </div>
                </div>

                <!-- Nivel 3 -->
                <div
                    class="flex flex-col h-full bg-slate-900/50 rounded-[2.5rem] p-6 border border-slate-800 hover:border-emerald-500/50 transition-all group"
                >
                    <div class="mb-6 px-2">
                        <span
                            class="text-emerald-500 font-black text-xs uppercase tracking-[0.2em]"
                            >Nivel 3</span
                        >
                        <h3
                            class="text-xl font-black text-white uppercase italic mt-1"
                        >
                            Ventas 24/7
                        </h3>
                    </div>
                    <div
                        class="w-full h-44 bg-slate-800 rounded-[1.8rem] mb-6 overflow-hidden relative shrink-0 border border-white/5"
                    >
                        <img
                            src="/imgs/tienda-online-virtual-ecommerce-carrito-de-compras-pagos.webp"
                            alt="Mockup L3"
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                        />
                    </div>
                    <div class="space-y-4 mb-4 grow flex flex-col px-2">
                        <div
                            class="bg-emerald-900/20 p-4 rounded-2xl border border-emerald-500/20 min-h-[115px]"
                        >
                            <p
                                class="text-[10px] font-black text-emerald-400 uppercase mb-2"
                            >
                                ¿Es para mí?
                            </p>
                            <p class="text-sm text-slate-300 leading-snug">
                                Si vendes <strong>productos físicos</strong> y quieres
                                una <strong>tienda profesional</strong> que reciba
                                pagos y gestione inventario de forma automática siempre.
                            </p>
                        </div>
                        <div
                            class="bg-slate-800/20 p-4 rounded-2xl border border-dashed border-slate-700/50"
                        >
                            <p
                                class="text-[10px] font-black text-slate-500 uppercase mb-2"
