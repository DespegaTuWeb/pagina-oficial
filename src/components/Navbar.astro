---
import Icon from './Icon.astro';
import logo from '../assets/logo.svg';
---

<nav
    x-data="{ mobileMenuOpen: false, scrolled: false }"
    @scroll.window="scrolled = (window.pageYOffset > 50)"
    class="fixed top-0 left-0 w-full z-[999] transition-all duration-500 border-b bg-black/20 backdrop-blur-md border-white/10 py-4"
    :class="scrolled ? '!bg-slate-900/95 !border-slate-800 !py-2 md:!py-3 shadow-lg' : ''"
>
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
        <a
            href="/"
            class="font-black text-2xl md:text-3xl flex items-center gap-2 italic tracking-tighter shrink-0 transition-colors duration-300 text-white"
        >
            <img
                src={logo.src}
                alt="Logo DespegaTuWeb"
                class="w-auto h-8 md:h-10 transition-all duration-500"
                :class="scrolled ? '!h-6 md:!h-8' : ''"
                width="160"
                height="40"
                loading="eager"
                fetchpriority="high"
            />
            <span class="text-blue-500 uppercase">Despega</span><span
                class="uppercase text-white">TuWeb</span
            >
        </a>

        <div
            class="hidden md:flex gap-12 items-center font-bold text-xs transition-colors duration-300 text-white/90"
        >
            <div
                class="relative py-2"
                x-data="{ dropdownOpen: false }"
                @click.outside="dropdownOpen = false"
            >
                <button
                    @click="dropdownOpen = !dropdownOpen"
                    class="hover:text-blue-400 transition flex items-center gap-2 tracking-widest uppercase px-2 outline-none"
                >
                    TIPOS DE WEB
                    <Icon
                        name="fa6-solid:chevron-down"
                        class="text-[10px] ml-0.5 transition-transform duration-200 w-[10px] h-[10px]"
                        :class="dropdownOpen ? 'rotate-180' : ''"
                    />
                </button>

                <div
                    x-show="dropdownOpen"
                    x-transition:enter="transition ease-out duration-200"
                    x-transition:enter-start="opacity-0 translate-y-4"
                    x-transition:enter-end="opacity-100 translate-y-0"
                    class="absolute top-full left-0 w-[400px] pt-4 z-[1000]"
                    style="display: none"
                >
                    <div
                        class="bg-slate-900 border border-slate-700 shadow-2xl rounded-[2rem] overflow-hidden"
                    >
                        <div
                            class="px-6 py-3 bg-slate-800/50 border-b border-slate-700/50"
                        >
                            <span
                                class="text-[10px] text-slate-400 font-black uppercase tracking-widest"
                                >Niveles de Despegue</span
                            >
                        </div>

                        <a
                            href="/planes#l1"
                            class="flex items-center gap-4 px-6 py-5 hover:bg-slate-800 transition border-b border-slate-800 group text-slate-200"
                        >
                            <div
                                class="w-11 h-11 bg-orange-500/20 text-orange-400 rounded-xl flex items-center justify-center text-xl shrink-0 group-hover:scale-110 transition-transform"
                            >
                                <Icon name="fa6-solid:bolt" class="w-5 h-5" />
                            </div>
                            <div class="grow">
                                <div
                                    class="flex justify-between items-center gap-4"
                                >
                                    <span
                                        class="font-black text-sm uppercase italic text-white"
                                        >IDENTIDAD DIGITAL</span
                                    >
                                    <span
                                        class="bg-slate-800 text-white border border-slate-600 text-[10px] font-black px-3 py-2 rounded-lg min-w-[70px] inline-flex justify-center items-center leading-none"
                                        >S/ 450</span
                                    >
                                </div>
                                <p
                                    class="text-[10px] text-slate-400 font-medium leading-tight mt-1"
                                >
                                    Tu marca en internet en solo 48 horas.
                                </p>
                            </div>
                        </a>

                        <a
                            href="/planes#l2"
                            class="flex items-center gap-4 px-6 py-5 hover:bg-slate-800 transition border-b border-slate-800 group text-slate-200"
                        >
                            <div
                                class="w-11 h-11 bg-blue-500/20 text-blue-400 rounded-xl flex items-center justify-center text-xl shrink-0 group-hover:scale-110 transition-transform"
                            >
                                <Icon name="fa6-solid:building" class="w-5 h-5" />
                            </div>
                            <div class="grow">
                                <div
                                    class="flex justify-between items-center gap-4"
                                >
                                    <span
                                        class="font-black text-sm uppercase italic text-nowrap text-white"
                                        >PODER CORPORATIVO</span
                                    >
                                    <span
                                        class="bg-blue-600 text-white text-[10px] font-black px-3 py-2 rounded-lg min-w-[70px] inline-flex justify-center items-center leading-none"
                                        >S/ 1,000</span
                                    >
                                </div>
                                <p
                                    class="text-[10px] text-slate-400 font-medium leading-tight mt-1"
                                >
                                    Estatus corporativo con control total (CMS).
                                </p>
                            </div>
                        </a>

                        <a
                            href="/planes#l3"
                            class="flex items-center gap-4 px-6 py-5 hover:bg-slate-800 transition group text-slate-200"
                        >
                            <div
                                class="w-11 h-11 bg-emerald-500/20 text-emerald-400 rounded-xl flex items-center justify-center text-xl shrink-0 group-hover:scale-110 transition-transform"
                            >
                                <Icon name="fa6-solid:cart-shopping" class="w-5 h-5" />
                            </div>
                            <div class="grow">
                                <div
                                    class="flex justify-between items-center gap-4"
                                >
                                    <span
                                        class="font-black text-sm uppercase italic text-white"
                                        >VENTAS 24/7</span
                                    >
                                    <span
                                        class="bg-emerald-600 text-white text-[10px] font-black px-3 py-2 rounded-lg min-w-[70px] inline-flex justify-center items-center leading-none"
                                        >S/ 3,500</span
                                    >
                                </div>
                                <p
                                    class="text-[10px] text-slate-400 font-medium leading-tight mt-1"
                                >
                                    Tu sucursal 24/7 con pagos y stock.
                                </p>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            <a
                href="/portafolio"
                class="hover:text-blue-400 transition py-2 uppercase tracking-wider px-2"
                >Nuestros Trabajos</a
            >
            <a
                href="/#por-que-elegirnos"
                class="hover:text-blue-400 transition py-2 uppercase tracking-wider px-2"
                >¿Por qué elegirnos?</a
            >
        </div>

        <div class="md:hidden">
            <button
                @click="mobileMenuOpen = !mobileMenuOpen"
                class="text-white p-2 transition-colors hover:text-blue-400 outline-none relative z-[1001]"
                aria-label="Abrir menú"
            >
                <span x-show="!mobileMenuOpen">
                    <Icon name="fa6-solid:bars" class="w-6 h-6 transition-all duration-300" />
                </span>
                <span x-show="mobileMenuOpen" class="rotate-90 inline-block transition-all duration-300">
                    <Icon name="fa6-solid:xmark" class="w-6 h-6" />
                </span>
            </button>
        </div>
    </div>

    <div
        x-show="mobileMenuOpen"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 -translate-y-full"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100 translate-y-0"
        x-transition:leave-end="opacity-0 -translate-y-full"
        class="absolute top-full left-0 w-full bg-slate-900/95 backdrop-blur-xl border-b border-slate-800 shadow-2xl md:hidden overflow-hidden z-[1000]"
        style="display: none"
    >
        <div
            class="flex flex-col px-6 py-6 gap-4 font-bold text-sm tracking-widest uppercase text-white/90"
        >
            <div x-data="{ mobileDropdownOpen: false }" class="w-full">
                <button
                    @click="mobileDropdownOpen = !mobileDropdownOpen"
                    class="w-full flex justify-between items-center py-3 text-left hover:text-blue-400 transition-colors outline-none"
                >
                    TIPOS DE WEB
                    <Icon
                        name="fa6-solid:chevron-down"
                        class="w-4 h-4 transition-transform duration-300"
                        :class="mobileDropdownOpen ? 'rotate-180 text-blue-500' : ''"
                    />
                </button>

                <div
                    x-show="mobileDropdownOpen"
                    x-transition
                    class="flex flex-col gap-4 pl-4 pt-3 pb-3 border-l-2 border-slate-800 ml-2"
                >
                    <a
                        @click="mobileMenuOpen = false"
                        href="/planes#l1"
                        class="flex items-center gap-3 text-slate-300 hover:text-white transition-colors"
                    >
                        <Icon name="fa6-solid:bolt" class="text-orange-400 w-5 h-5" />
                        IDENTIDAD DIGITAL
                    </a>
                    <a
                        @click="mobileMenuOpen = false"
                        href="/planes#l2"
                        class="flex items-center gap-3 text-slate-300 hover:text-white transition-colors"
                    >
                        <Icon name="fa6-solid:building" class="text-blue-400 w-5 h-5" />
                        PODER CORPORATIVO
                    </a>
                    <a
                        @click="mobileMenuOpen = false"
                        href="/planes#l3"
                        class="flex items-center gap-3 text-slate-300 hover:text-white transition-colors"
                    >
                        <Icon name="fa6-solid:cart-shopping" class="text-emerald-400 w-5 h-5" />
                        VENTAS 24/7
                    </a>
                </div>
            </div>

            <div class="w-full h-px bg-slate-800/50"></div>
            <a
                @click="mobileMenuOpen = false"
                href="/portafolio"
                class="py-3 hover:text-blue-400 transition-colors"
                >Nuestros Trabajos</a
            >
            <div class="w-full h-px bg-slate-800/50"></div>
            <a
                @click="mobileMenuOpen = false"
                href="/#por-que-elegirnos"
                class="py-3 hover:text-blue-400 transition-colors"
                >¿Por qué elegirnos?</a
            >
        </div>
    </div>
</nav>
