---
import { Icon as AstroIcon } from 'astro-icon/components';

interface Props {
  name: string;
  class?: string;
  size?: number;
  'aria-label'?: string;
}

const { name, class: className, size, 'aria-label': ariaLabel } = Astro.props;
---

<AstroIcon
  name={name}
  class={className}
  {...size ? { width: size, height: size } : {}}
  aria-hidden={ariaLabel ? undefined : true}
  aria-label={ariaLabel}
/>
