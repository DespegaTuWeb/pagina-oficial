---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import yape from '../assets/yape.webp';
import plin from '../assets/plin.webp';
import visa from '../assets/visa.webp';
---

<footer
    class="relative bg-slate-950 pt-16 pb-8 overflow-hidden mt-auto border-t border-slate-800 z-10"
>
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 md:w-1/2 h-[1px] bg-gradient-to-r from-transparent via-blue-500/50 to-transparent"
    >
    </div>
    <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-lg h-32 bg-blue-900/10 blur-[100px] rounded-t-full pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="text-center mb-12">
            <div
                class="font-black text-3xl md:text-4xl italic mb-6 tracking-tighter drop-shadow-lg"
            >
                <Icon
                    name="fa6-solid:rocket"
                    class="text-blue-500 mr-2 hover:-translate-y-1 transition-transform duration-300 w-8 h-8 inline-block align-middle"
                />
                <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-blue-600 uppercase"
                    >Despega
                </span><span class="uppercase text-white">TuWeb</span>
            </div>

            <p
                class="text-slate-400 font-medium text-sm md:text-lg max-w-2xl mx-auto leading-relaxed"
            >
                "Más de
                <span
                    class="inline-block bg-blue-900/30 border border-blue-500/30 text-white font-bold px-3 py-1 rounded-xl mx-1 shadow-[0_0_15px_rgba(59,130,246,0.2)]"
                    >100 negocios</span
                >
                ya están volando en internet. ¿Faltas tú?"
            </p>
        </div>

        <div
            class="flex flex-col items-center bg-slate-900/30 border border-slate-800/50 rounded-3xl py-8 px-2 md:px-4 max-w-3xl mx-auto mb-12 backdrop-blur-sm"
        >
            <p
                class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-6 text-center"
            >
                Medios de pago oficiales
            </p>

            <div
                class="flex items-center justify-center gap-4 md:gap-12 flex-nowrap w-full"
            >
                <div
                    class="w-[50px] md:w-[70px] h-[30px] md:h-[40px] shrink-0 flex items-center justify-center hover:scale-110 hover:drop-shadow-[0_0_15px_rgba(147,51,234,0.8)] transition-all duration-300"
                >
                    <Image
                        src={yape}
                        alt="Yape"
                        class="max-w-full max-h-full object-contain block"
                        width={70}
                        loading="lazy"
                    />
                </div>
                <div
                    class="w-[50px] md:w-[70px] h-[30px] md:h-[40px] shrink-0 flex items-center justify-center hover:scale-110 hover:drop-shadow-[0_0_15px_rgba(6,182,212,0.8)] transition-all duration-300"
                >
                    <Image
                        src={plin}
                        alt="Plin"
                        class="max-w-full max-h-full object-contain block"
                        width={70}
                        loading="lazy"
                    />
                </div>
                <div
                    class="w-[50px] md:w-[70px] h-[30px] md:h-[40px] shrink-0 flex items-center justify-center hover:scale-110 hover:drop-shadow-[0_0_15px_rgba(59,130,246,0.8)] transition-all duration-300"
                >
                    <Image
                        src={visa}
                        alt="Visa"
                        class="max-w-full max-h-full object-contain block"
                        width={70}
                        loading="lazy"
                    />
                </div>
                <div
                    class="w-[50px] md:w-[70px] h-[30px] md:h-[40px] shrink-0 flex items-center justify-center text-[28px] md:text-[40px] text-slate-300 hover:text-white hover:scale-110 hover:drop-shadow-[0_0_15px_rgba(255,255,255,0.6)] transition-all duration-300"
                >
                    <Icon name="fa6-solid:building-columns" class="w-8 h-8 md:w-10 md:h-10" />
                </div>
            </div>
        </div>

        <div
            class="border-t border-slate-800/80 pt-8 flex flex-col md:flex-row justify-between items-center text-[10px] md:text-[11px] font-bold text-slate-500 uppercase tracking-widest gap-4 md:gap-0"
        >
            <p>&copy; 2026 DespegaTuWeb - Lima</p>
            <div class="flex flex-wrap justify-center gap-4 md:gap-6">
                <a
                    href="/privacidad"
                    class="hover:text-blue-400 transition-colors">Privacidad</a
                >
                <span class="text-slate-800 hidden md:inline">|</span>
                <a
                    href="/acuerdo-de-servicio"
                    class="hover:text-blue-400 transition-colors"
                    >Acuerdo de Servicio</a
                >
            </div>
        </div>
    </div>
</footer>
