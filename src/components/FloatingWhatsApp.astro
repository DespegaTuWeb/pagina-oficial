---
import Icon from './Icon.astro';
---

<div class="fixed bottom-4 right-4 md:bottom-6 md:right-6 z-[9999] group">
    <div
        class="hidden md:block absolute -inset-1 bg-gradient-to-r from-blue-600 to-cyan-500 rounded-full blur opacity-20 group-hover:opacity-100 transition duration-1000 group-hover:duration-200"
    >
    </div>

    <a
        href="https://wa.me/51963896469?text=Hola%20DespegaTuWeb,%20quiero%20iniciar%20mi%20despegue%20digital%20🚀"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar a DespegaTuWeb por WhatsApp"
        class="hidden md:flex relative items-center gap-3 bg-white border border-slate-200 px-3.5 py-2 rounded-full hover:border-blue-500/50 transition-all duration-300 shadow-xl"
    >
        <div class="relative flex shrink-0">
            <div
                class="absolute -top-0.5 -right-0.5 w-2.5 h-2.5 bg-green-500 rounded-full border-2 border-white z-10"
            >
            </div>
            <div
                class="w-9 h-9 bg-green-500/10 text-green-500 rounded-full flex items-center justify-center"
            >
                <Icon name="fa6-brands:whatsapp" class="w-5 h-5" />
            </div>
        </div>

        <div class="flex flex-col pr-1">
            <span
                class="text-[9px] font-black text-blue-500 uppercase tracking-widest leading-none mb-1"
                >Online</span
            >
            <span
                class="text-slate-900 font-bold text-xs tracking-tight leading-none"
                >Iniciar Despegue!</span
            >
        </div>
    </a>

    <a
        href="https://wa.me/51963896469?text=Hola%20DespegaTuWeb,%20quiero%20iniciar%20mi%20despegue%20digital%20🚀"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar a DespegaTuWeb por WhatsApp (versión móvil)"
        class="flex md:hidden items-center justify-center bg-white/90 backdrop-blur-md border border-slate-200 p-3 rounded-full shadow-xl text-green-600"
    >
        <Icon name="fa6-brands:whatsapp" class="w-6 h-6" />
    </a>
</div>
